@page "/"
@inject NavigationManager Nav
@inject CatalogService CatalogService
@attribute [StreamRendering]

<PageTitle>FindMeAGift</PageTitle>
<SectionContent SectionName="page-header-title">Find the perfect gift</SectionContent>
<SectionContent SectionName="page-header-subtitle">Unique handcrafted gifts for every occasion and every person in your life.</SectionContent>

<div class="catalog">
    <CatalogSearch BrandId="@BrandId" ItemTypeId="@ItemTypeId" />

    @if (catalogResult is null && agentItems is null)
    {
        <p>Loading...</p>
    }
    else if (agentItems is not null)
    {
        <div class="catalog-content">
            <div class="agent-results-banner">
                <span>🎁 Ivy's picks for you</span>
                <a href="/" class="clear-filter">Show all</a>
            </div>
            <div class="catalog-items">
                @foreach (var item in agentItems)
                {
                    <CatalogListItem Item="@item" />
                }
            </div>
        </div>
    }
    else
    {
        <div class="catalog-content">
            <div class="catalog-items">
                @foreach (var item in catalogResult!.Data)
                {
                    <CatalogListItem Item="@item" />
                }
            </div>

            <div class="page-links">
                @foreach (var pageIndex in GetVisiblePageIndexes(catalogResult!))
                {
                    <NavLink ActiveClass="active-page" Match="@NavLinkMatch.All" href="@Nav.GetUriWithQueryParameter("page", pageIndex == 1 ? null : pageIndex)">@pageIndex</NavLink>
                }
            </div>
        </div>
    }
</div>

@code {
    const int PageSize = 9;

    [SupplyParameterFromQuery]
    public int? Page { get; set; }

    [SupplyParameterFromQuery(Name = "brand")]
    public int? BrandId { get; set; }

    [SupplyParameterFromQuery(Name = "type")]
    public int? ItemTypeId { get; set; }

    [SupplyParameterFromQuery(Name = "items")]
    public string? AgentItemIds { get; set; }

    CatalogResult? catalogResult;
    List<CatalogItem>? agentItems;
    string? agentItemIds;

    static IEnumerable<int> GetVisiblePageIndexes(CatalogResult result)
        => Enumerable.Range(1, (int)Math.Ceiling(1.0 * result.Count / PageSize));

    protected override async Task OnInitializedAsync()
    {
        if (!string.IsNullOrEmpty(AgentItemIds))
        {
            agentItemIds = AgentItemIds;
            var ids = AgentItemIds.Split(',', StringSplitOptions.RemoveEmptyEntries)
                .Select(s => int.TryParse(s, out var n) ? n : 0)
                .Where(n => n > 0)
                .ToList();
            if (ids.Count > 0)
            {
                try
                {
                    agentItems = await CatalogService.GetCatalogItems(ids);
                }
                catch
                {
                    // Fallback to normal catalog if by-ids fails
                    catalogResult = await CatalogService.GetCatalogItems(0, PageSize, BrandId, ItemTypeId);
                }
            }
            else
            {
                catalogResult = await CatalogService.GetCatalogItems(0, PageSize, BrandId, ItemTypeId);
            }
        }
        else
        {
            catalogResult = await CatalogService.GetCatalogItems(
                Page.GetValueOrDefault(1) - 1,
                PageSize,
                BrandId,
                ItemTypeId);
        }
    }

    private void ClearAgentFilter()
    {
        Nav.NavigateTo("/", forceLoad: true);
    }
}
